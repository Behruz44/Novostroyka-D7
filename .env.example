# ============================================================
# DEVELOPMENT (docker-compose)
# ============================================================

# Database (used by Prisma locally)
DATABASE_URL="postgresql://user:changeme@localhost:5432/stroycontrol?schema=public"

# Docker Compose: PostgreSQL credentials
POSTGRES_USER="stroycontrol"
POSTGRES_PASSWORD="changeme"
POSTGRES_DB="stroycontrol"

# Docker Compose: MinIO credentials
MINIO_ROOT_USER="changeme"
MINIO_ROOT_PASSWORD="changeme"

# Auth
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# S3 / MinIO (dev)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="changeme"
S3_SECRET_ACCESS_KEY="changeme"
S3_BUCKET_NAME="stroycontrol"

# Seed (local dev only)
SEED_ADMIN_PASSWORD="changeme-admin"
SEED_OWNER_PASSWORD="changeme-owner"
SEED_FOREMAN_PASSWORD="changeme-foreman"

# ============================================================
# PRODUCTION (Railway)
# Set these in Railway dashboard → Variables. Do NOT use
# ${VAR:-default} syntax — that is docker-compose only.
# ============================================================

# Database — Railway provides DATABASE_URL automatically when you
# add a Postgres service. Copy the connection string here.
# DATABASE_URL="postgresql://..."  (from Railway Postgres plugin)

# Auth — generate a random secret: openssl rand -base64 32
# NEXTAUTH_SECRET="<random-32+ chars>"
# NEXTAUTH_URL="https://your-app.up.railway.app"

# S3 / Cloudflare R2 (prod)
# S3_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
# S3_REGION="auto"
# S3_ACCESS_KEY_ID="<R2 access key ID>"
# S3_SECRET_ACCESS_KEY="<R2 secret access key>"
# S3_BUCKET_NAME="<R2 bucket name>"

# Seed (production — set strong passwords before first deploy)
# SEED_ADMIN_PASSWORD="<strong password>"
# SEED_OWNER_PASSWORD="<strong password>"
# SEED_FOREMAN_PASSWORD="<strong password>"
