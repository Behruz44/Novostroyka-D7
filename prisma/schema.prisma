// Prisma schema - TASK 1.1 full data model
// See PROJECT_BRAIN section 3 for complete data model

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  FOREMAN
  ADMIN
}

enum StageStatus {
  WAIT
  REVIEW
  DONE
}

enum MarkStatus {
  REVIEW
  APPROVED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  phone        String   @unique
  name         String
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projectMemberships ProjectMember[]
  stageMarks         StageMark[] @relation("StageMarkCreatedBy")
  reviewedStageMarks StageMark[] @relation("StageMarkReviewedBy")
  expenses           Expense[]
  eventLogs          EventLog[]
  chatThreads        ChatThread[]
}

model Project {
  id               String   @id @default(cuid())
  name             String
  address          String?
  totalBudgetMinor BigInt
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  members     ProjectMember[]
  stages      Stage[]
  expenses    Expense[]
  budgetLines BudgetLine[]
  eventLogs   EventLog[]
  chatThreads ChatThread[]
  contractors Contractor[]
}

model ProjectMember {
  id        String @id @default(cuid())
  projectId String
  userId    String
  role      Role

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model Stage {
  id           String      @id @default(cuid())
  projectId    String
  name         String
  floor        Int
  weightBp     Int
  order        Int
  status       StageStatus @default(WAIT)
  plannedStart DateTime?
  plannedEnd   DateTime?
  contractorId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contractor Contractor? @relation(fields: [contractorId], references: [id], onDelete: SetNull)
  stageMarks StageMark[]
  expenses   Expense[]

  @@index([projectId])
  @@index([projectId, order])
  @@index([contractorId])
}

model StageMark {
  id              String     @id @default(cuid())
  stageId         String
  status          MarkStatus @default(REVIEW)
  photoKeys       String[]
  comment         String?
  createdBy       String
  clientRequestId String?    @unique
  reviewedAt      DateTime?
  reviewedBy      String?
  createdAt       DateTime   @default(now())

  stage    Stage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  user     User  @relation("StageMarkCreatedBy", fields: [createdBy], references: [id], onDelete: Cascade)
  reviewer User? @relation("StageMarkReviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([stageId])
}

model Expense {
  id              String   @id @default(cuid())
  projectId       String
  budgetLineId    String
  stageId         String?
  contractorId    String?
  amountMinor     BigInt
  description     String
  expenseDate     DateTime
  createdBy       String
  clientRequestId String?  @unique
  createdAt       DateTime @default(now())

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  budgetLine BudgetLine  @relation(fields: [budgetLineId], references: [id], onDelete: Restrict)
  stage      Stage?      @relation(fields: [stageId], references: [id], onDelete: SetNull)
  contractor Contractor? @relation(fields: [contractorId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([projectId, expenseDate])
  @@index([budgetLineId])
  @@index([stageId])
  @@index([contractorId])
}

model Contractor {
  id        String   @id @default(cuid())
  projectId String
  name      String
  specialty String
  phone     String?
  createdAt DateTime @default(now())

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stages   Stage[]
  expenses Expense[]

  @@index([projectId])
}

model BudgetLine {
  id           String   @id @default(cuid())
  projectId    String
  category     String
  plannedMinor BigInt
  createdAt    DateTime @default(now())

  project  Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@unique([projectId, category])
  @@index([projectId])
}

model ChatThread {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([projectId])
  @@index([userId])
  @@index([projectId, updatedAt])
}

model ChatMessage {
  id        String   @id @default(cuid())
  threadId  String
  role      String
  content   String
  photoKeys String[]
  createdAt DateTime @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([threadId, createdAt])
}

model EventLog {
  id              String   @id @default(cuid())
  projectId       String
  userId          String
  action          String
  entity          String
  entityId        String
  metadata        Json?
  clientRequestId String?
  createdAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, createdAt])
}

model PhotoDetection {
  id         String   @id @default(cuid())
  photoKey   String   @unique
  detections Json
  modelId    String
  imageWidth Int
  imageHeight Int
  createdAt  DateTime @default(now())
}
